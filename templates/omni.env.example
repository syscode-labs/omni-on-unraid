# Omni release tag from github.com/siderolabs/omni
OMNI_VERSION=v1.5.8

# Public endpoint used by clients
OMNI_DOMAIN=omni.example.internal

# ACME disabled by default for homelab; terminate TLS upstream or provide certs
OMNI_TLS_MODE=external

# Data path on host
OMNI_DATA_DIR=./data

# Optional: custom registry mirror/proxy
# OMNI_IMAGE_REGISTRY=

# IaC/operator inputs
# Libvirt URI used by Terraform
# Example (set for your environment): qemu+tcp://<libvirt-host>/system
OMNI_LIBVIRT_URI=

# Libvirt network/bridge used by VM NIC (use br0 for direct LAN IP)
OMNI_LIBVIRT_BRIDGE=br0
# Optional fixed VM NIC MAC (keeps cloud-init netplan MAC match stable across replacement)
# OMNI_VM_MAC=52:54:00:8e:74:fb
# Back-compat alias (deprecated): OMNI_LIBVIRT_NETWORK
# OMNI_LIBVIRT_NETWORK=br0

# VM domain name in libvirt
OMNI_VM_NAME=omni-vm

# Path to VM base image on libvirt host (absolute path on libvirt host filesystem)
OMNI_BASE_IMAGE_PATH=

# Local operator path used by Terraform when importing base image into libvirt
OMNI_LOCAL_BASE_IMAGE_PATH=./.cache/images/ubuntu-noble-cloudimg-amd64.qcow2

# Optional URL for automatic image preparation task
OMNI_BASE_IMAGE_URL=https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img

# Optional SSH target used to place/check image on remote libvirt host (user@host)
# If unset, image checks/download run locally.
OMNI_LIBVIRT_IMAGE_SSH_TARGET=

# Path to SSH public key file on operator machine
OMNI_SSH_PUBLIC_KEY_PATH=

# Optional private key path for SSH operations (defaults to OMNI_SSH_PUBLIC_KEY_PATH without .pub)
# OMNI_SSH_IDENTITY_FILE=

# Optional custom SSH options for deploy (space-separated ssh CLI options)
# OMNI_SSH_OPTS=-o BatchMode=yes -o StrictHostKeyChecking=no

# Optional, if you want VM bootstrap to join Tailscale
OMNI_TAILSCALE_AUTHKEY=
OMNI_TAILSCALE_HOSTNAME=omni

# Remote deploy defaults
OMNI_SSH_USER=omni
# Optional override. If unset, deploy target is auto-discovered from libvirt VM IP.
# OMNI_SSH_TARGET=
OMNI_REMOTE_DIR=/opt/omni
# Relay staging path on jump host (when relay mode is used)
OMNI_JUMP_STAGE_DIR=/tmp/omni-deploy-src
# Comma-separated target IP prefixes requiring relay via OMNI_LIBVIRT_IMAGE_SSH_TARGET
OMNI_DEPLOY_RELAY_IP_PREFIXES=192.168.122.

# Optional Omni compose overrides used by scripts/build-compose-env.sh
# OMNI_IMG_TAG=v1.5.8
# OMNI_NAME=omni
# OMNI_EVENT_SINK_PORT=8091
# OMNI_BIND_ADDR=0.0.0.0:443
# OMNI_MACHINE_API_BIND_ADDR=0.0.0.0:8090
# OMNI_K8S_PROXY_BIND_ADDR=0.0.0.0:8100
# OMNI_ADVERTISED_API_URL=https://omni.example.internal
# OMNI_ADVERTISED_K8S_PROXY_URL=https://omni.example.internal:8100/
# OMNI_SIDEROLINK_API_URL=https://omni.example.internal:8090/
# OMNI_WG_ADDR=omni.example.internal:50180
# OMNI_INITIAL_USER_EMAILS=admin@example.internal
# OMNI_ADMIN_EMAIL=admin@example.internal
# OMNI_AUTH_ARGS=
