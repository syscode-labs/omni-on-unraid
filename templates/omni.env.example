# Omni release tag from github.com/siderolabs/omni
OMNI_VERSION=v1.5.8

# Public endpoint used by clients
OMNI_DOMAIN=omni.example.internal

# ACME disabled by default for homelab; terminate TLS upstream or provide certs
OMNI_TLS_MODE=external

# Data path on host
OMNI_DATA_DIR=./data

# Optional: custom registry mirror/proxy
# OMNI_IMAGE_REGISTRY=

# IaC/operator inputs
# Libvirt URI used by Terraform
# For remote Unraid libvirt over SSH, example: qemu+ssh://omniops@bookofshadows/system
OMNI_LIBVIRT_URI=qemu+ssh://omniops@bookofshadows/system

# Path to VM base image on libvirt host (absolute path on libvirt host filesystem)
OMNI_BASE_IMAGE_PATH=/mnt/user/appdata/omni/images/ubuntu-noble-cloudimg-amd64.qcow2

# Optional URL for automatic image preparation task
OMNI_BASE_IMAGE_URL=https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img

# Optional SSH target used to place/check image on remote libvirt host (user@host)
# If unset, image checks/download run locally.
OMNI_LIBVIRT_IMAGE_SSH_TARGET=omniops@bookofshadows

# Path to SSH public key file on operator machine
OMNI_SSH_PUBLIC_KEY_PATH=

# Optional, if you want VM bootstrap to join Tailscale
OMNI_TAILSCALE_AUTHKEY=
OMNI_TAILSCALE_HOSTNAME=omni

# Remote deploy defaults
OMNI_SSH_USER=omni
# Optional override. If unset, deploy target becomes: ${OMNI_SSH_USER}@${OMNI_TAILSCALE_HOSTNAME}
# OMNI_SSH_TARGET=
OMNI_REMOTE_DIR=/opt/omni
